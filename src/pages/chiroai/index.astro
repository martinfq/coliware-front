<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:root {
		--bg: #0b0b0f;
		--surface: #13131a;
		--border: #222230;
		--accent: #7c9fcf;
		--accent-glow: rgba(124, 159, 207, 0.15);
		--text: #e0e0e0;
		--muted: #888;
	}

	body {
		background: var(--bg);
		color: var(--text);
		font-family: sans-serif;
		line-height: 1.6;
	}

	/* Nav */
	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 2rem;
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		background: rgba(11, 11, 15, 0.85);
		backdrop-filter: blur(12px);
		z-index: 10;
	}

	.nav-logo {
		font-weight: 700;
		font-size: 1.1rem;
		letter-spacing: 0.05em;
		color: #fff;
	}

	.nav-link {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: #fff;
	}

	/* Hero */
	.hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 3rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 6rem 2rem 5rem;
	}

	.hero-content {
		flex: 1;
		max-width: 560px;
	}

	.badge {
		display: inline-block;
		background: var(--accent-glow);
		color: var(--accent);
		border: 1px solid rgba(124, 159, 207, 0.3);
		border-radius: 999px;
		padding: 0.25rem 0.9rem;
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		margin-bottom: 1.5rem;
	}

	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 800;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 1.25rem;
	}

	.accent {
		color: var(--accent);
	}

	.tagline {
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		color: var(--muted);
		margin-bottom: 2rem;
		max-width: 420px;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn-primary {
		background: var(--accent);
		color: #0b0b0f;
		font-weight: 700;
		padding: 0.75rem 1.75rem;
		border-radius: 8px;
		text-decoration: none;
		font-size: 0.95rem;
		transition: opacity 0.2s;
	}

	.btn-primary:hover {
		opacity: 0.85;
	}

	.btn-secondary {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border);
		padding: 0.75rem 1.75rem;
		border-radius: 8px;
		text-decoration: none;
		font-size: 0.95rem;
		transition: border-color 0.2s, color 0.2s;
	}

	.btn-secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	/* Phone mock */
	.hero-visual {
		flex-shrink: 0;
	}

	.phone-mock {
		width: 220px;
		height: 400px;
		border: 2px solid var(--border);
		border-radius: 32px;
		background: var(--surface);
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 0 80px var(--accent-glow);
	}

	.phone-screen {
		width: 75%;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.screen-line {
		height: 10px;
		border-radius: 6px;
		background: var(--border);
		width: 100%;
	}

	.screen-line.short { width: 55%; }
	.screen-line.medium { width: 75%; }

	/* Features */
	.features {
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 2rem;
		border-top: 1px solid var(--border);
	}

	.section-title {
		font-size: clamp(1.5rem, 4vw, 2.25rem);
		font-weight: 700;
		color: #fff;
		text-align: center;
		margin-bottom: 3rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
	}

	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.75rem 1.5rem;
		transition: border-color 0.3s, box-shadow 0.3s;
	}

	.card:hover {
		border-color: rgba(124, 159, 207, 0.4);
		box-shadow: 0 0 24px var(--accent-glow);
	}

	.icon {
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.card h3 {
		font-size: 1rem;
		font-weight: 600;
		color: #fff;
		margin-bottom: 0.5rem;
	}

	.card p {
		font-size: 0.9rem;
		color: var(--muted);
	}

	/* Download */
	.download {
		text-align: center;
		padding: 5rem 2rem;
		border-top: 1px solid var(--border);
	}

	.download h2 {
		font-size: clamp(1.5rem, 4vw, 2.25rem);
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.75rem;
	}

	.download p {
		color: var(--muted);
		margin-bottom: 2.5rem;
	}

	.store-btns {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.store-btn {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 0.75rem 1.5rem;
		text-decoration: none;
		color: #fff;
		transition: border-color 0.2s, box-shadow 0.2s;
		min-width: 160px;
	}

	.store-btn:hover {
		border-color: rgba(124, 159, 207, 0.4);
		box-shadow: 0 0 20px var(--accent-glow);
	}

	.store-icon {
		font-size: 1.5rem;
	}

	.store-btn span {
		display: flex;
		flex-direction: column;
		text-align: left;
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.store-btn small {
		font-size: 0.7rem;
		color: var(--muted);
		font-weight: 400;
	}

	/* Footer */
	.footer {
		border-top: 1px solid var(--border);
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		text-align: center;
	}

	.footer-logo {
		font-weight: 700;
		font-size: 0.9rem;
		letter-spacing: 0.15em;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer-logo:hover {
		color: #fff;
	}

	.footer-links {
		display: flex;
		gap: 1.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-links a {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.875rem;
		transition: color 0.2s;
	}

	.footer-links a:hover {
		color: #fff;
	}

	.copyright {
		font-size: 0.8rem;
		color: #444;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero {
			flex-direction: column;
			padding: 4rem 1.5rem 3rem;
			text-align: center;
		}

		.tagline {
			margin-inline: auto;
		}

		.cta-group {
			justify-content: center;
		}

		.hero-visual {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.nav {
			padding: 1rem 1.25rem;
		}

		.features,
		.download {
			padding: 3.5rem 1.25rem;
		}
	}
</style>
