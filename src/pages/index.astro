<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		height: 100vh;
		height: 100svh;
		font-family: sans-serif;
	}

	.layout {
		display: grid;
		grid-template-rows: 1fr 1fr;
		height: 100vh;
		height: 100svh;
	}

	.top {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #0f0f0f;
		color: #fff;
		padding: 1rem;
	}

	.top h1 {
		font-size: clamp(2.5rem, 10vw, 8rem);
		letter-spacing: 0.2em;
		font-weight: 700;
		text-align: center;
	}

	.bottom {
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.panel {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
	}

	.panel h2 {
		font-size: clamp(1.5rem, 6vw, 5rem);
		letter-spacing: 0.1em;
		font-weight: 600;
		text-align: center;
		transition: letter-spacing 0.3s ease;
	}

	.left {
		background: #1a1a2e;
		color: #e0e0e0;
		border-right: 1px solid #333;
		transition: background 0.3s ease, color 0.3s ease;
	}

	.left:hover {
		background: #2a2a5e;
		color: #ffffff;
		cursor: pointer;
	}

	.left:hover h2 {
		letter-spacing: 0.2em;
	}

	.right {
		background: #16213e;
		color: #e0e0e0;
		transition: background 0.3s ease, color 0.3s ease;
	}

	.right:hover {
		background: #0f3460;
		color: #ffffff;
		cursor: pointer;
	}

	.right:hover h2 {
		letter-spacing: 0.2em;
	}

	/* Tablet (640px – 1023px): reduce letter-spacing slightly */
	@media (max-width: 1023px) {
		.top h1 {
			letter-spacing: 0.1em;
		}
	}

	/* Mobile (< 640px): stack panels vertically */
	@media (max-width: 639px) {
		.layout {
			grid-template-rows: 1fr 2fr;
		}

		.bottom {
			grid-template-columns: 1fr;
			grid-template-rows: 1fr 1fr;
		}

		.left {
			border-right: none;
			border-bottom: 1px solid #333;
		}

		.top h1 {
			letter-spacing: 0.08em;
		}
	}
</style>
