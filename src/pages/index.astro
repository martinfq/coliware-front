<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		height: 100vh;
		font-family: sans-serif;
	}

	.layout {
		display: grid;
		grid-template-rows: 1fr 1fr;
		height: 100vh;
	}

	.top {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #0f0f0f;
		color: #fff;
	}

	.top h1 {
		font-size: 8rem;
		letter-spacing: 0.2em;
		font-weight: 700;
	}

	.bottom {
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.panel {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.panel h2 {
		font-size: 5rem;
		letter-spacing: 0.1em;
		font-weight: 600;
	}

	.left {
		background: #1a1a2e;
		color: #e0e0e0;
		border-right: 1px solid #333;
		transition: background 0.3s ease, color 0.3s ease;
	}

	.left:hover {
		background: #2a2a5e;
		color: #ffffff;
		cursor: pointer;
	}

	.left:hover h2 {
		letter-spacing: 0.2em;
		transition: letter-spacing 0.3s ease;
	}

	.right {
